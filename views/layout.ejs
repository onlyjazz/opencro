<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenCRO - Real-world MedTech cybersecurity. Clear FDA. Survive real world.</title>
  <link rel="stylesheet" href="/css/main.css">
  <!-- Open Graph Metadata -->
  <meta property="og:title" content="Real-world MedTech cybersecurity.">
  <meta property="og:description" content="Yesterday you designed for patients. Today you design for survival. Clear FDA Cybersecurity today and survive the real world tomorrow. A security and privacy requirement for AI for clinical applications. Cyber devices.">
  <meta property="og:image" content="https://opencro.com/images/linkedin-featured.png">
