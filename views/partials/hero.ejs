<section class="section hero-section">
  <div class="container">
    <div class="hero">
      <div class="hero-content">
        <% if (typeof eyebrow !== 'undefined') { %>
          <p class="text-eyebrow"><%= eyebrow %></p>
        <% } %>
        <% if (typeof headline !== 'undefined') { %>
          <h2 class="text-hero"><%- headline %></h2>
        <% } %>
        <% if (typeof bridge !== 'undefined') { %>
          <p class="text-bridge"><%- bridge %></p>
        <% } %>
        <% if (typeof proof !== 'undefined') { %>
          <p class="text-proof"><%- proof %></p>
        <% } %>
        <% if ((typeof primaryCTA !== 'undefined') || (typeof secondaryCTA !== 'undefined')) { %>
          <div class="hero-ctas">
            <% if (typeof primaryCTA !== 'undefined') { %>
              <a href="<%= primaryCTA.href %>" class="cta-primary"><%= primaryCTA.text %></a>
            <% } %>
            <% if (typeof secondaryCTA !== 'undefined') { %>
              <a href="<%= secondaryCTA.href %>" class="cta-secondary"><%= secondaryCTA.text %></a>
            <% } %>
          </div>
        <% } %>
      </div>
      <% if (typeof diagram !== 'undefined') { %>
        <div class="hero-diagram">
          <div class="hero-diagram-inner">
            <%- diagram %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>
